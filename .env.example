# ===========================================================================
# Environment for the production / Dokploy stack (docker-compose.yml).
# Copy to `.env` and fill in. NEVER commit a real `.env`.
# In Dokploy, set these as the Compose service's Environment variables.
# ===========================================================================

# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-me-to-a-long-random-50-char-secret
DJANGO_DEBUG=False
# Add your Dokploy domain here, e.g. shop.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# TLS is terminated at the edge proxy (Dokploy/Traefik), which forwards plain
# HTTP internally — so Django must NOT force an HTTPS redirect (would loop).
DJANGO_SECURE_SSL_REDIRECT=False

# --- Admin account ---
# Created automatically on first boot (and ensured on every boot) so production
# has a ready superuser for /admin/. Change these to your own before deploying.
DJANGO_SUPERUSER_EMAIL=admin@marketplace.com
DJANGO_SUPERUSER_PASSWORD=change-me-to-a-strong-admin-password

# --- Database (the bundled Postgres service) ---
POSTGRES_DB=marketplace
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgres://marketplace:change-me-strong-db-password@db:5432/marketplace
DB_CONN_MAX_AGE=60

# --- Redis (cache / Celery / Channels) ---
REDIS_URL=redis://redis:6379/0
CACHE_URL=rediscache://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=django-db

# --- CORS (empty: single-domain deploy via the frontend nginx proxy) ---
# Only needed if you split the SPA and API onto separate domains.
CORS_ALLOWED_ORIGINS=

# --- CSRF (required for the Django admin behind an HTTPS proxy) ---
# Add your HTTPS domain(s), scheme included, e.g. https://shop.example.com
# (defaults to CORS_ALLOWED_ORIGINS if left blank). The SPA/API use JWT and
# don't need this — it only affects /django-admin/ login.
CSRF_TRUSTED_ORIGINS=

# --- Media storage: local volume by default (USE_S3=False) ---
USE_S3=False

# --- Email (use a real SMTP URL in production) ---
EMAIL_URL=consolemail://

# --- Frontend ---
# Relative API base so the SPA hits the same origin (nginx proxies to backend).
VITE_API_URL=/api/v1
# Host port the frontend is published on (attach your Dokploy domain to it).
FRONTEND_PORT=8080

# --- Optional error monitoring ---
DJANGO_SENTRY_DSN=
