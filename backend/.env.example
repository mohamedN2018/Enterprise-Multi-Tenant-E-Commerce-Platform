# ===========================================================================
# Environment configuration template.
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# ===========================================================================

# --- Core ---
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database ---
# Local dev defaults to SQLite (backend/db.sqlite3) — leave DATABASE_URL unset
# and you need no Postgres server. To use Postgres locally instead, uncomment:
# DATABASE_URL=postgres://marketplace:marketplace@localhost:5432/marketplace
DB_CONN_MAX_AGE=60

# --- Cache / Channels / Celery ---
# All optional locally: cache falls back to local-memory, channels to in-memory,
# and Celery runs tasks inline (CELERY_TASK_ALWAYS_EAGER). Set these only if you
# actually run Redis locally.
# REDIS_URL=redis://localhost:6379/0
# CACHE_URL=rediscache://localhost:6379/1
# CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=django-db

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Object storage (MinIO / S3) ---
USE_S3=False
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=marketplace-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1

# --- Email (console backend in dev) ---
EMAIL_URL=consolemail://

# --- Production monitoring (optional) ---
DJANGO_SENTRY_DSN=
